{
	"name": "calls",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "apps/frontend/calls/src",
	"projectType": "application",
	"tags": [],
	"// targets": "to see all targets run: nx show project calls --web",
	"targets": {
		"lint:fix": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["eslint --fix {projectRoot}/**/*.{ts,tsx,js,jsx}"]
			}
		},
		"test": {
			"options": {
				"command": "echo test"
			}
		},
		"e2e": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"pnpm exec playwright test --config=apps/frontend/task-manager/playwright.config.ts"
				],
				"cwd": "{workspaceRoot}"
			}
		},
		"e2e:headed": {
			"executor": "nx:run-commands",
			"options": {
				"commands": [
					"pnpm exec playwright test --config=apps/frontend/task-manager/playwright.config.ts --headed"
				],
				"cwd": "{workspaceRoot}"
			}
		}
	}
}
