{
    "extends": "next/core-web-vitals",
    "rules": {
        "react/react-in-jsx-scope": "off",
        "linebreak-style": ["error", "windows"],
        "no-console": [
            "warn",
            {
                "allow": ["warn", "error", "info"]
            }
        ],
        "comma-dangle": ["warn", "never"],
        "camelcase": "error",
        "eqeqeq": "error",
        "max-len": [
            "warn",
            {
                "code": 120,
                "tabWidth": 4
            }
        ],
        "max-depth": [
            "warn",
            {
                "max": 4
            }
        ],
        "max-lines": [
            "warn",
            {
                "max": 200,
                "skipBlankLines": true,
                "skipComments": true
            }
        ],
        "newline-after-var": "warn",
        "no-debugger": "warn",
        "no-dupe-keys": "error",
        "no-duplicate-case": "error",
        "semi": [
            "warn",
            "always",
            {
                "omitLastInOneLineBlock": true
            }
        ],
        "quotes": ["warn", "double"]
    }
}
